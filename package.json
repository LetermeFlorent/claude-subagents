{
  "name": "claude-subagents",
  "displayName": "Claude Subagents",
  "description": "Item de barre de statut listant les sous-agents Claude Code actifs (type, description, duree) que l'extension officielle n'affiche pas.",
  "version": "0.3.0",
  "publisher": "letermeflorent",
  "license": "MIT",
  "icon": "icon.png",
  "repository": { "type": "git", "url": "https://github.com/LetermeFlorent/claude-subagents.git" },
  "homepage": "https://github.com/LetermeFlorent/claude-subagents#readme",
  "bugs": { "url": "https://github.com/LetermeFlorent/claude-subagents/issues" },
  "keywords": ["claude", "anthropic", "subagents", "agents", "claude code"],
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "extensionKind": ["ui"],
  "contributes": {
    "commands": [
      { "command": "claudeSubagents.refresh", "title": "Claude Subagents: Rafraichir" },
      { "command": "claudeSubagents.showList", "title": "Claude Subagents: Voir la liste des agents actifs" }
    ],
    "configuration": {
      "title": "Claude Subagents",
      "properties": {
        "claudeSubagents.refreshSeconds": { "type": "number", "default": 3, "description": "Intervalle de rafraichissement local (secondes)." },
        "claudeSubagents.remoteHosts": { "type": "array", "items": { "type": "string" }, "default": [], "description": "Alias SSH (~/.ssh/config) a interroger en plus du local pour compter les sous-agents actifs (ex: [\"growthfit\"]). Necessite ssh en PATH et une cle sans mot de passe. Vide = desactive." }
      }
    }
  }
}
